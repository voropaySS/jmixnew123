<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1" author="competitions">
        <createTable tableName="DEPARTMENT">
            <column name="ID" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_DEPARTMENT"/>
            </column>
            <column name="NUM" type="INT"/>
            <column name="NAME" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>
    <changeSet id="2" author="competitions">
        <createTable tableName="DOCUMENT">
            <column name="ID" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_DOCUMENT"/>
            </column>
            <column name="NAME" type="VARCHAR(255)"/>
            <column name="OWNER_ID" type="UUID"/>
            <column name="STATUS" type="VARCHAR(255)"/>
            <column name="CREATED_BY" type="VARCHAR(255)"/>
            <column name="CREATED_DATE" type="${offsetDateTime.type}"/>
        </createTable>
    </changeSet>
    <changeSet id="3" author="competitions">
        <createTable tableName="DOCUMENT_VERSION">
            <column name="ID" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_DOCUMENT_VERSION"/>
            </column>
            <column name="FILE_REF" type="CLOB"/>
            <column name="NAME" type="VARCHAR(255)"/>
            <column name="NUM_VERSION" type="INT"/>
            <column name="CREATED_BY" type="VARCHAR(255)"/>
            <column name="CREATED_DATE" type="${offsetDateTime.type}"/>
            <column name="DOCUMENT_ID" type="UUID"/>
        </createTable>
    </changeSet>
    <changeSet id="4" author="competitions">
        <createTable tableName="DOC_ROLE">
            <column name="ID" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_DOC_ROLE"/>
            </column>
            <column name="DOC_VERSION_ID" type="UUID"/>
            <column name="OWNER_ID" type="UUID"/>
        </createTable>
    </changeSet>
    <changeSet id="5" author="competitions">
        <createTable tableName="DOC_ROLE_USER_LINK">
            <column name="DOC_ROLE_ID" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_DOC_ROLE_USER_LINK"/>
            </column>
            <column name="USER_ID" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_DOC_ROLE_USER_LINK"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="6" author="competitions">
        <createTable tableName="POSITION_">
            <column name="ID" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_POSITION_"/>
            </column>
            <column name="SHORT_NAME" type="VARCHAR(255)"/>
            <column name="LONG_NAME" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>
    <changeSet id="7" author="competitions">
        <createTable tableName="SOGLASOVANIE">
            <column name="ID" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_SOGLASOVANIE"/>
            </column>
            <column name="STATUS_SOGL" type="VARCHAR(255)"/>
            <column name="HISTORY" type="CLOB"/>
            <column name="DOC_VERSION_ID" type="UUID"/>
        </createTable>
    </changeSet>
    <changeSet id="8" author="competitions">
        <createTable tableName="USER_SOGL">
            <column name="ID" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_USER_SOGL"/>
            </column>
            <column name="USER_ID" type="UUID"/>
            <column name="COMMENT_" type="CLOB"/>
            <column name="SOGLASOVANIE_ID" type="UUID"/>
        </createTable>
    </changeSet>
    <changeSet id="9" author="competitions">
        <addColumn tableName="USER_">
            <column name="BIRTH_DATE" type="DATE"/>
            <column name="DEPARTMENT_ID" type="UUID"/>
            <column name="PERS_NUMBER" type="VARCHAR(255)"/>
            <column name="PERS_NUMBER_RUK" type="VARCHAR(255)"/>
            <column name="POL" type="VARCHAR(255)"/>
            <column name="POSITION_ID" type="UUID"/>
        </addColumn>
    </changeSet>
    <changeSet id="10" author="competitions">
        <createIndex indexName="IDX_DOCUMENT_OWNER" tableName="DOCUMENT">
            <column name="OWNER_ID"/>
        </createIndex>

        <addForeignKeyConstraint baseColumnNames="OWNER_ID" baseTableName="DOCUMENT"
                                 constraintName="FK_DOCUMENT_ON_OWNER" referencedColumnNames="ID"
                                 referencedTableName="USER_"/>
    </changeSet>
    <changeSet id="11" author="competitions">
        <createIndex indexName="IDX_DOCUMENT_VERSION_DOCUMENT" tableName="DOCUMENT_VERSION">
            <column name="DOCUMENT_ID"/>
        </createIndex>

        <addForeignKeyConstraint baseColumnNames="DOCUMENT_ID" baseTableName="DOCUMENT_VERSION"
                                 constraintName="FK_DOCUMENT_VERSION_ON_DOCUMENT" referencedColumnNames="ID"
                                 referencedTableName="DOCUMENT"/>
    </changeSet>
    <changeSet id="12" author="competitions">
        <createIndex indexName="IDX_DOC_ROLE_DOC_VERSION" tableName="DOC_ROLE">
            <column name="DOC_VERSION_ID"/>
        </createIndex>

        <addForeignKeyConstraint baseColumnNames="DOC_VERSION_ID" baseTableName="DOC_ROLE"
                                 constraintName="FK_DOC_ROLE_ON_DOC_VERSION" referencedColumnNames="ID"
                                 referencedTableName="DOCUMENT_VERSION"/>
    </changeSet>
    <changeSet id="13" author="competitions">
        <createIndex indexName="IDX_DOC_ROLE_OWNER" tableName="DOC_ROLE">
            <column name="OWNER_ID"/>
        </createIndex>

        <addForeignKeyConstraint baseColumnNames="OWNER_ID" baseTableName="DOC_ROLE"
                                 constraintName="FK_DOC_ROLE_ON_OWNER" referencedColumnNames="ID"
                                 referencedTableName="USER_"/>
    </changeSet>
    <changeSet id="14" author="competitions">
        <createIndex indexName="IDX_SOGLASOVANIE_DOC_VERSION" tableName="SOGLASOVANIE">
            <column name="DOC_VERSION_ID"/>
        </createIndex>

        <addForeignKeyConstraint baseColumnNames="DOC_VERSION_ID" baseTableName="SOGLASOVANIE"
                                 constraintName="FK_SOGLASOVANIE_ON_DOC_VERSION" referencedColumnNames="ID"
                                 referencedTableName="DOCUMENT_VERSION"/>
    </changeSet>
    <changeSet id="15" author="competitions">
        <createIndex indexName="IDX_USER_SOGL_SOGLASOVANIE" tableName="USER_SOGL">
            <column name="SOGLASOVANIE_ID"/>
        </createIndex>

        <addForeignKeyConstraint baseColumnNames="SOGLASOVANIE_ID" baseTableName="USER_SOGL"
                                 constraintName="FK_USER_SOGL_ON_SOGLASOVANIE" referencedColumnNames="ID"
                                 referencedTableName="SOGLASOVANIE"/>
    </changeSet>
    <changeSet id="16" author="competitions">
        <createIndex indexName="IDX_USER_SOGL_USER" tableName="USER_SOGL">
            <column name="USER_ID"/>
        </createIndex>

        <addForeignKeyConstraint baseColumnNames="USER_ID" baseTableName="USER_SOGL"
                                 constraintName="FK_USER_SOGL_ON_USER" referencedColumnNames="ID"
                                 referencedTableName="USER_"/>
    </changeSet>
    <changeSet id="17" author="competitions">
        <createIndex indexName="IDX_USER__DEPARTMENT" tableName="USER_">
            <column name="DEPARTMENT_ID"/>
        </createIndex>

        <addForeignKeyConstraint baseColumnNames="DEPARTMENT_ID" baseTableName="USER_"
                                 constraintName="FK_USER__ON_DEPARTMENT" referencedColumnNames="ID"
                                 referencedTableName="DEPARTMENT"/>
    </changeSet>
    <changeSet id="18" author="competitions">
        <createIndex indexName="IDX_USER__POSITION" tableName="USER_">
            <column name="POSITION_ID"/>
        </createIndex>

        <addForeignKeyConstraint baseColumnNames="POSITION_ID" baseTableName="USER_"
                                 constraintName="FK_USER__ON_POSITION" referencedColumnNames="ID"
                                 referencedTableName="POSITION_"/>
    </changeSet>
    <changeSet id="19" author="competitions">
        <addForeignKeyConstraint baseColumnNames="DOC_ROLE_ID" baseTableName="DOC_ROLE_USER_LINK"
                                 constraintName="FK_DOCROLUSE_ON_DOC_ROLE" referencedColumnNames="ID"
                                 referencedTableName="DOC_ROLE"/>
    </changeSet>
    <changeSet id="20" author="competitions">
        <addForeignKeyConstraint baseColumnNames="USER_ID" baseTableName="DOC_ROLE_USER_LINK"
                                 constraintName="FK_DOCROLUSE_ON_USER" referencedColumnNames="ID"
                                 referencedTableName="USER_"/>
    </changeSet>
</databaseChangeLog>